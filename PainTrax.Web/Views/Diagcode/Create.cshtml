@model PainTrax.Web.Models.tbl_diagcodes
<main id="main" class="main">

    <div class="pagetitle">
        <h1>Manage Diagnosis </h1>
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="diagcode">List</a></li>
                <li class="breadcrumb-item active">Create</li>
            </ol>
        </nav>
    </div><!-- End Page Title -->

    <section class="section">
        <div class="row">
            <div class="col-lg-12">

                <div class="card">
                    <div class="card-body">

                        @*<h5 class="card-title">Add Designation</h5>*@
                        <div class="row">
                            <div class="col-sm-12 col-md-6">
                                <h5 class="card-title">Add Diagnosis </h5>
                            </div>
                            <div class="col-sm-12 col-md-6" style="text-align:right;padding-top:5px;">
                            </div>
                        </div>

                        <!-- General Form Elements -->
                        <form asp-action="Create" asp-controller="Diagcode">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="row mb-3">
                                        <label for="BodyPart" class="col-md-4 col-lg-3 col-form-label">Body Part</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input type="text" tabindex="1" class="form-control requred" asp-for="BodyPart">

                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label for="Description" class="col-md-4 col-lg-3 col-form-label">Description</label>
                                        <div class="col-md-8 col-lg-9">
                                            <textarea type="text" tabindex="3" class="form-control" asp-for="Description"></textarea>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label for="PreSelect" class="col-md-4 col-lg-3 col-form-label"></label>
                                        <div class="col-md-8 col-lg-9">

                                            <div class="form-check">
                                                <input class="form-check-input" asp-for="PreSelect" type="checkbox" />
                                                <label class="form-check-label" for="PreSelect">
                                                    Pre Select
                                                </label>
                                            </div>

                                        </div>
                                    </div>

                                    <div class="row mb-3">

                                        <div class="col-sm-10">
                                            <button type="submit" class="btn btn-primary">Save</button>
                                            <a class="btn btn-primary" asp-action="Index" asp-controller="diagcode">Back</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="row mb-3">
                                        <label for="DiagCode" class="col-md-4 col-lg-3 col-form-label">Diag Code</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input type="text" class="form-control" asp-for="DiagCode">

                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label for="Description" class="col-md-4 col-lg-3 col-form-label">Display Order</label>
                                        <div class="col-md-8 col-lg-9">
                                            <input type="text" tabindex="5" class="form-control" asp-for="display_order" />
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <label for="DiagCode" class="col-md-4 col-lg-3 col-form-label">Diag Code Group</label>
                                        <div class="col-md-8 col-lg-9 d-flex gap-2">
                                            <select class="form-select searchable-dropdown" asp-for="DiagCodeGroup" asp-items="@ViewBag.groupList"></select>
                                            <button type="button" class="btn btn-outline-secondary" id="btnOpenDiagModal" onclick="fnShowGroup()" title="Add Group">+</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </section>
    <div class="modal fade" id="diagCodeModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Diagnosis Code Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="newDiagName" class="form-label">Group name</label>
                        <input id="newDiagName" class="form-control" />
                    </div>
                    <div id="diagError" class="text-danger small d-none"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="btnSaveDiag" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

</main><!-- End #main -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<script>
    function fnShowGroup(){
        $("#diagCodeModal").modal('show');
    }

    $("#btnSaveDiag").click(function () {

        var groupName = $("#newDiagName").val().trim();

        if (groupName === "") {
            $("#diagError").removeClass("d-none").text("Group name is required");
            return;
        }

        $("#diagError").addClass("d-none");
        var url="@Url.Action("SaveGroup", "Diagcode")";
        $.ajax({
            url: url,
            type: 'POST',
            data: { name: groupName },
            success: function (res) {
                if (res.success) {
                    $("#diagCodeModal").modal('hide');
                    $("#newDiagName").val("");

                      var newOption = new Option(groupName, groupName, true, true);
        $("#DiagCodeGroup").append(newOption).trigger('change');

        // Optional: select it
        $("#DiagCodeGroup").val(groupName);


                    // optional: refresh list or dropdown
                    alert("Saved successfully");
                } else {
                    $("#diagError").removeClass("d-none").text(res.message);
                }
            },
            error: function () {
                $("#diagError").removeClass("d-none").text("Something went wrong");
            }
        });

    });
</script>

