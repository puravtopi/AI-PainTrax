<link href="~/assets/img/favicon.png" rel="icon">
<link href="~/assets/img/apple-touch-icon.png" rel="apple-touch-icon">

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

@{
    Layout = "~/Views/Shared/_IntakeLayout.cshtml";  // Use the admin layout
}
<style>
    input.form-control.d-inline,
    select.form-select.d-inline,
    textarea.form-control.d-inline {
        border: none;
        border-bottom: 1px solid black;
        border-radius: 0;
        padding: 2px 5px;
    }

    .mic-btn {
        right: 10px;
        top: 10px;
        cursor: pointer;
        color: #007bff;
    }

    #uploadLoader {
        display: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

        #uploadLoader.show {
            display: flex !important;
        }

</style>
<main id="main" class="main" style="margin-left:0px!important">

    <section class="section">
        <div class="col-lg-12">

            <div class="row">
                <!-- LEFT: FORM -->
                <div class="col-md-12 col-12" id="formSection" name="formSection">
                    <button id="openPreview"
                            class="btn btn-sm btn-outline-primary mt-3"
                            style="display:none;">
                        Show Preview
                    </button>
                    <button id="uploadDL"
                            class="btn btn-sm btn-outline-primary mt-3" onclick="fnshowDLPopup()">
                        Upload Driving License
                    </button>
                    <form method="post" id="patientForm" name="patientForm" class="container my-4">
                        <input type="hidden" id="hdId" name="hdId" value="@ViewBag.Id" />
                        <input type="hidden" id="PatientSubmitDate" name="PatientSubmitDate" value="@ViewBag.SubmitDate" />
                        <input type="hidden" id="LocationId" name="LocationId" value="@ViewBag.LocId" />
                        <input type="hidden" id="DLPath" name="DLPath" />
                        <input type="hidden" id="hdIEId" name="hdIEId" />
                        <input type="hidden" id="hdSelectedBody" name="hdSelectedBody" />
                        <input type="hidden" id="Diagnosis" name="Diagnosis" />
                        <input type="hidden" id="TreatmentIds" name="TreatmentIds" />
                        <input type="hidden" id="TreatmentDesc" name="TreatmentDesc" />
                        <input type="hidden" id="TreatmentDelimitDesc" name="TreatmentDelimitDesc" />
                        <h4 class="text-center mb-4 fw-bold">Patient Injury Report
                            <a href='@Url.Action("AIInitialIntake", "IntakeForm", new { locid = ViewBag.LocId })'>
                                Click for V1
                            </a>

                        </h4>

                        <div class="border p-4 rounded shadow-sm" style="line-height: 2; font-size: 15px;background-color:white">
                            <b><i>*Note: Please do not use single quot(') in any fields.</i></b>
                            <div class="accordion" id="accordionExample">
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="headingOne">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                            Patient Details
                                        </button>
                                    </h2>
                                    <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                                        <div class="accordion-body">
                                            <br />
                                            <!-- Patient Info -->
                                            <p>
                                                Patient LName:
                                                <input id="LN" name="LN" class="form-control d-inline" style="width:150px;" />
                                                FName:
                                                <input id="FN" name="FN" class="form-control d-inline" style="width:150px;" />
                                                @*  <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'PatientName')"></i> *@
                                                Gender
                                                <select id="Gender" name="Gender" class="form-select d-inline w-auto" style="width:50px !important">
                                                    <option value="male">M</option>
                                                    <option value="female">F</option>
                                                </select>
                                                &nbsp;&nbsp;
                                                handed:
                                                <select id="DominantHand" name="DominantHand" class="form-select d-inline w-auto" style="width:50px !important">
                                                    <option value="right-handed">R</option>
                                                    <option value="left-handed">L</option>
                                                </select>
                                                &nbsp;&nbsp;
                                                DOE
                                                <input id="DOE" name="DOE" type="date" class="form-control d-inline w-auto" />
                                                &nbsp;&nbsp;
                                                Location: &nbsp;&nbsp;
                                                <span id="lblLocation">
                                                    @ViewBag.LocName
                                                </span>
                                            </p>

                                            <p>
                                                DOB:
                                                <input id="DOB" name="DOB" type="date" class="form-control d-inline w-auto" />
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                Age:
                                                <input id="Age" name="Age" class="form-control d-inline" style="width:50px" /> years
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                Height:
                                                <input id="Height" name="Height" class="form-control d-inline" style="width:150px" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'Height')"></i>
                                                Weight:
                                                <input id="Weight" name="Weight" class="form-control d-inline" style="width:150px" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'Weight')"></i>
                                                lbs.
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                DOA:
                                                <input id="DOA" name="DOA" type="date" class="form-control d-inline w-auto" />
                                            </p>

                                            <!-- Work -->
                                            <p>
                                                Currently working:
                                                <input type="radio" name="IsWorking" value="The patient is currently working." /> Yes
                                                <input type="radio" name="IsWorking" value="The patient stopped working immediately after accident." /> No
                                                <br />
                                                Job title:
                                                <input id="JobTitle" name="JobTitle" class="form-control d-inline w-auto" style="min-width:90%;" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'JobTitle')"></i>
                                            </p>

                                            <p>
                                                If not working, stopped immediately after accident:
                                                <input type="radio" name="StoppedAfterAccident" value="Yes" /> Yes
                                                <input type="radio" name="StoppedAfterAccident" value="No" /> No
                                                <br />
                                                Reason:
                                                <textarea id="NotWorkingReason" name="NotWorkingReason" class="form-control d-inline w-50" style="min-width:90%;"></textarea>
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'NotWorkingReason')"></i>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="headingTwo">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                            Chief complaint
                                        </button>
                                    </h2>
                                    <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#accordionExample">
                                        <div class="accordion-body">
                                            <!-- Chief Complaint -->
                                            <p>
                                                <b> Chief complaint:</b>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Right Shoulder" data-section="rshSection" data-pe="rshPE" /> R/SH</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Left Shoulder" data-section="lshSection" data-pe="lshPE" /> L/SH</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Right Knee" data-section="rknSection" data-pe="rknPE" /> R/KN</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Left Knee" data-section="lknSection" data-pe="lknPE" /> L/KN</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Right Elbow" /> R/Elb</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Left Elbow" /> L/Elb</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Right Wrist" /> R/Wrist</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Left Wrist" /> L/Wrist</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Right Hip" /> R/Hip</label>
                                                <label><input type="checkbox" class="chkMulti" name="Complaints" value="Left Hip" /> L/Hip</label>
                                                <input type="text" id="OtherBodyPart" name="OtherBodyPart" class="form-control d-inline w-auto" placeholder="other" />
                                            </p>

                                            <!-- Injury Type -->
                                            <p>
                                                Type of Injury:
                                                <label><input type="radio" name="InjuryType" value="motor vehicle" /> MVA</label>
                                                <label><input type="radio" name="InjuryType" value="work-related" /> Work-related</label>
                                                <label><input type="radio" name="InjuryType" value="lien" /> Lien</label>
                                            </p>

                                            <div id="divWC" style="display:none;">
                                                <!-- Paragraph Description -->
                                                <p>
                                                    The patient reports that on
                                                    <input type="date" id="lblDOA" name="lblDOA" class="form-control d-inline w-auto" />
                                                    while
                                                    <select id="Activity" class="form-select d-inline" style="width:350px" name="Activity">
                                                        <option value=""></option>
                                                        <option value="performing regular job duties">performing regular job duties </option>
                                                        <option value="performing assigned work tasks">performing assigned work tasks </option>
                                                        <option value="engaged in usual occupational activities">engaged in usual occupational activities </option>
                                                    </select>,
                                                    they sustained a work-related injury when

                                                    <select id="Incident" class="form-select d-inline" style="width:350px" name="Incident">
                                                        <option value=""></option>
                                                        <option value="slipped">slipped</option>
                                                        <option value="tripped">tripped</option>
                                                        <option value="lost balance">lost balance</option>
                                                        <option value="was struck by an object">was struck by an object</option>
                                                        <option value="lifted or carried an object">lifted or carried an object</option>
                                                        <option value="pushed or pulled equipment">pushed or pulled equipment</option>
                                                        <option value="twisted or turned abruptly">twisted or turned abruptly</option>
                                                        <option value="experienced repetitive strain">experienced repetitive strain</option>
                                                        <option value="experienced sudden forceful movement">experienced sudden forceful movement</option>
                                                    </select>.
                                                </p>

                                                <p>
                                                    The incident occurred
                                                    <select name="IncidentType" class="form-select d-inline" style="width:250px" id="IncidentType">
                                                        <option value=""></option>
                                                        <option value="suddenly">suddenly</option>
                                                        <option value="unexpectedly">unexpectedly</option>
                                                        <option value="during normal work">during normal work</option>
                                                    </select>
                                                    and involved

                                                    <select name="Mechanism" class="form-select d-inline" style="width:300px" id="Mechanism">
                                                        <option value=""></option>
                                                        <option value="direct impact">direct impact </option>
                                                        <option value="overexertion">overexertion</option>
                                                        <option value="awkward positioning">awkward positioning </option>
                                                        <option value="forceful movement">forceful movement  </option>
                                                        <option value="repetitive motion">repetitive motion</option>
                                                        <option value="loss of footing">loss of footing</option>
                                                        <option value="sudden loading of the body">sudden loading of the body</option>
                                                    </select>
                                                </p>

                                                <p>
                                                    As a result, the patient experienced
                                                    <select class="form-select d-inline" style="width:150px" name="SymptomOnset" id="SymptomOnset">
                                                        <option value=""></option>
                                                        <option value="immediate">immediate</option>
                                                        <option value="same-day">same-day</option>
                                                        <option value="progressive">progressive</option>
                                                    </select>
                                                    pain affecting
                                                    <input type="text" class="form-control d-inline w-25" name="BodyPart" id="BodyPart" placeholder="body part" />.
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'BodyPart')"></i>
                                                    which was
                                                    <select class="form-select d-inline" style="width:350px" name="PainEffect" id="PainEffect">
                                                        <option value=""></option>
                                                        <option value="not present prior to this incident">not present prior to this incident</option>
                                                        <option value="significantly less severe prior to this incident">significantly less severe prior to this incident</option>

                                                    </select>.
                                                </p>

                                                <p>
                                                    Since the time of injury, the patient reports
                                                    <select class="form-select d-inline" style="width:150px" name="SymptomPattern" id="SymptomPattern">
                                                        <option value=""></option>
                                                        <option value="persistent">persistent</option>
                                                        <option value="worsening">worsening</option>
                                                        <option value="fluctuating">fluctuating</option>
                                                    </select>
                                                    symptoms that interfere with .
                                                    <select class="form-select d-inline" style="width:350px" name="DailyActivities" id="DailyActivities">
                                                        <option value=""></option>
                                                        <option value="work duties">work duties</option>
                                                        <option value="activities of daily living ">activities of daily living</option>
                                                        <option value="physical tasks required for employment">physical tasks required for employment</option>
                                                    </select>
                                                </p>
                                            </div>
                                            <p>
                                                Accident Description
                                                <textarea id="AccidentDescription" name="AccidentDescription" class="form-control d-inline" style="width:95%"></textarea>
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'AccidentDescription')"></i>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="headingThree">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                            Pre-Injury Functional Baseline
                                        </button>
                                    </h2>
                                    <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#accordionExample">
                                        <div class="accordion-body">
                                            <p>
                                                Prior to the patient’s
                                                <select class="form-select d-inline" style="width:200px" name="AccidentType" id="AccidentType">

                                                    <option value="work incident">accident</option>
                                                    <option value="work incident">work incident</option>

                                                </select>
                                                , the patient reports being able to perform normal activities.

                                                <br />

                                                <label><input type="radio" name="PreInjury" value="Yes"> Yes</label>
                                                <label><input type="radio" name="PreInjury" value="No"> No</label>
                                            </p>
                                            <p>
                                                <span id="preInjuryDetailsBox" style="display:none;">
                                                    <textarea id="PreInjuryDetails" class="form-control d-inline" style="width:95%" placeholder="Specify details"></textarea>
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'PreInjuryDetails')"></i>
                                                </span>
                                            </p>

                                            <!-- Patient Type -->
                                            <p>
                                                Patient reports being:
                                                <label><input type="checkbox" class="chkMulti" name="PatientType" value="Bicyclist"> Bicyclist</label>
                                                <label><input type="checkbox" class="chkMulti" name="PatientType" value="Pedestrian"> Pedestrian</label>
                                                <label><input type="checkbox" class="chkMulti" name="PatientType" value="Motorcyclist"> Motorcyclist</label>
                                                <label><input type="checkbox" class="chkMulti" name="PatientType" value="Driver"> Driver</label>
                                                <label><input type="checkbox" class="chkMulti" name="PatientType" value="Passenger"> Passenger</label>
                                            </p>

                                            <!-- Vehicle Hit -->
                                            <p>
                                                Vehicle hit:
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Rear"> Rear</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Front"> Front</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Driver side front/rear"> Driver-side front/rear</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Driver sideswipe"> Driver sideswipe</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Driver side T-boned"> Driver side T-boned</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Passenger side front/rear"> Passenger-side front/rear</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="Passenger-side swiped"> Passenger-side swiped</label>
                                                <label><input type="checkbox" class="chkMulti" name="VehicleHit" value="T-boned"> T-boned</label>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="headingFour">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseThree">
                                            Mechanism of Injury (Describe Forces & Body Position)
                                        </button>
                                    </h2>
                                    <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour" data-bs-parent="#accordionExample">
                                        <div class="accordion-body">

                                            <p>
                                                Patient describes sudden forceful impact involving
                                                <select id="MechanismInvolving" class="form-select d-inline" style="width:150px">
                                                    <option>acceleration</option>
                                                    <option>deceleration </option>

                                                </select>
                                                <label><input type="radio" name="MechanismChoice" value="Yes"> and</label>
                                                <label><input type="radio" name="MechanismChoice" value="No"> or</label>
                                                direct trauma, resulting in
                                                <select id="MechanismResulting" class="form-select d-inline" style="width:150px">
                                                    <option>immediate</option>
                                                    <option>gradual</option>

                                                </select>
                                                onset of pain to the body parts described in chief complaint.
                                            </p>

                                            <!-- Airbag -->
                                            <p>
                                                Air bags deployed:
                                                <label><input type="radio" name="Airbag" value="Yes"> Yes</label>
                                                <label><input type="radio" name="Airbag" value="No"> No</label>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                EMS arrived:
                                                <label><input type="radio" name="EMS" value="Yes"> Yes</label>
                                                <label><input type="radio" name="EMS" value="No"> No</label>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                Police contacted:
                                                <label><input type="radio" name="Police" value="Yes"> Yes</label>
                                                <label><input type="radio" name="Police" value="No"> No</label>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                Police report:
                                                <label><input type="radio" name="PoliceReport" value="Yes"> Yes</label>
                                                <label><input type="radio" name="PoliceReport" value="No"> No</label>
                                            </p>

                                            <!-- Hospital -->
                                            <p>
                                                Went to hospital:
                                                <label><input type="radio" name="Hospital" value="Yes"> Yes</label>
                                                <label><input type="radio" name="Hospital" value="No"> No</label>
                                                <div id="divHospital" style="display:none">

                                                    Hospital name:
                                                    <input id="HospitalName" class="form-control d-inline w-25" />
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'HospitalName')"></i>
                                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                    Records:
                                                    <label><input type="radio" name="Records" value="Yes"> Yes</label>
                                                    <label><input type="radio" name="Records" value="No"> No</label>
                                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                    How did you get to hospital:
                                                    <label><input type="checkbox" class="chkMulti" name="Transport" value="Ambulance"> Ambulance</label>
                                                    <label><input type="checkbox" class="chkMulti" name="Transport" value="Car"> Car</label>
                                                    <label><input type="checkbox" class="chkMulti" name="Transport" value="Uber"> Uber</label>
                                                    <label><input type="checkbox" class="chkMulti" name="Transport" value="Cab"> Cab</label>
                                                    <label><input type="checkbox" class="chkMulti" name="Transport" value="Friend"> Friend</label>
                                                </div>
                                            </p>

                                            <!-- Symptoms -->
                                            <p>
                                                Symptoms began:
                                                <label><input type="radio" name="SymptomsStart" value="Immediately"> Immediately</label>
                                                <label><input type="radio" name="SymptomsStart" value="Hours"> Within hours</label>
                                                <label><input type="radio" name="SymptomsStart" value="Same day"> Same day</label>
                                                <label><input type="radio" name="SymptomsStart" value="Next day"> Following day</label>
                                            </p>

                                            <p>
                                                Since onset, symptoms have:
                                                <label><input type="radio" name="SymptomsProgress" value="Persisted"> Persisted</label>
                                                <label><input type="radio" name="SymptomsProgress" value="Worsened"> Worsened</label>
                                                <label><input type="radio" name="SymptomsProgress" value="Improved"> Improved partially</label>
                                                <label><input type="radio" name="SymptomsProgress" value="Fluctuated"> Fluctuated</label>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="headingFive">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="false" aria-controls="collapseTwo">
                                            Medical History & Functional Status
                                        </button>
                                    </h2>
                                    <div id="collapseFive" class="accordion-collapse collapse" aria-labelledby="headingFive" data-bs-parent="#accordionExample">
                                        <div class="accordion-body">
                                            <!-- PMH -->
                                            <p>
                                                PMH:
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="None"> None</label>
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="Diabetes"> Diabetes</label>
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="HTN"> HTN</label>
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="HLD"> HLD</label>
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="Asthma"> Asthma</label>
                                                <label><input type="checkbox" class="chkMulti" name="PMH" value="Cardiac"> Cardiac</label>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                Other:
                                                <input id="PMHOther" class="form-control d-inline w-25" style="min-width:37%" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'PMHOther')"></i>
                                            </p>

                                            <!-- PSH -->
                                            <p>
                                                PSH:
                                                <input id="PSH" class="form-control d-inline w-50" placeholder="None or details" style="min-width:80%" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'PSH')"></i>
                                            </p>

                                            <!-- Meds -->
                                            <p>
                                                Meds:
                                                <label><input type="radio" name="Meds" value="The patient is not taking any medication at this time."> None</label>
                                                <label><input type="radio" name="Meds" value="The patient is taking {{MedsOther}} pain medications p.r.n."> Pain meds PRN</label>

                                                <input id="MedsOther" class="form-control d-inline w-25" />
                                                <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'MedsOther')"></i>
                                            </p>

                                            <!-- Allergies -->
                                            <p>
                                                Drug Allergies:
                                                <label><input type="radio" name="Allergy" value="NO KNOWN DRUG ALLERGIES."> NKDA</label>
                                                <label><input type="radio" name="Allergy" value="Yes"> Yes</label>
                                                <span id="divAllergy" style="display:none">
                                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                    Drug:
                                                    <input id="AllergyDrug" class="form-control d-inline w-25" />
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'AllergyDrug')"></i>
                                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                                                    What Allergy:
                                                    <input id="AllergyReaction" class="form-control d-inline w-25" />
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'AllergyReaction')"></i>
                                                </span>
                                            </p>

                                            <!-- Social History -->
                                            <p>
                                                Smoke:
                                                <label><input type="radio" name="Smoke" value="Yes"> Y</label>
                                                <label><input type="radio" name="Smoke" value="No"> N</label>
                                                <span id="divSmoke" style="display:none">
                                                    <input id="PPD" class="form-control d-inline" style="width:150px" /> PPD.
                                                    <i class="fa fa-microphone d-inline mic-btn" onclick="startVoice(this,'PPD')"></i>
                                                </span>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
