<div class="modal fade" id="fuModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="modeltitle">Upload Driving License</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- Patient Name -->
                <div class="mb-3">
                    <label class="form-label">Upload Image</label>
                    <input type="file" id="fup" accept="image/*" capture="environment" />
                </div>
                <!-- ✅ Loader Overlay -->
                <div id="uploadLoader"
                     style="display:none; position:absolute; top:0; left:0; width:100%; height:100%;
                background: rgba(255,255,255,0.7); z-index:999;
                align-items:center; justify-content:center;">

                    <div style="text-align:center;">
                        <div class="spinner-border text-primary"></div>
                        <p>Processing image...</p>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="fnUploadDL()">Upload</button>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="treatmentModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="modeltitle">Select Treatment / Plan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
